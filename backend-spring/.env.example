# Copy to .env and fill in. Load with: `export $(cat .env | xargs)` on Linux/macOS,
# or configure as a run-configuration env block in your IDE.

# --- MySQL (external, e.g. AWS RDS) -----------------------------------------
# Include serverTimezone + useSSL for managed providers.
DATABASE_URL=jdbc:mysql://your-rds-endpoint:3306/algotech?serverTimezone=UTC&useSSL=true&allowPublicKeyRetrieval=true
DATABASE_USERNAME=algotech
DATABASE_PASSWORD=change-me

# --- SendGrid ---------------------------------------------------------------
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@algotechfed.com
ADMIN_EMAIL=chouaib.gherbi@algotechfed.com

# --- CORS -------------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
FRONTEND_ORIGIN=http://localhost:5173

# --- Server -----------------------------------------------------------------
PORT=8080
