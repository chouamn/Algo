# Copy to .env.local for local development, or set these in your host
# (Vercel / Netlify / etc.) env vars for production builds.
# Only variables prefixed VITE_ are exposed to the browser.

# Base URL of the Spring Boot backend. Include the scheme but no trailing slash.
#   local dev:   http://localhost:8080
#   production:  https://api.algotechfed.com
VITE_API_URL=http://localhost:8080
